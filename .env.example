# DynamoDB
DYNAMODB_TABLE_NAME=BlogPosts
AWS_REGION=us-east-1

# Local development only (Amplify uses its IAM role in production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Bluesky
BLUESKY_IDENTIFIER=
